rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidId(id) { 
      // Allows letters, numbers, hyphens, and underscores for generic IDs
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function isValidUserProfile(data) {
      return data.keys().hasAll(['email']) 
        && data.email is string && data.email.size() > 0 && data.email.size() <= 100
        && (!data.keys().hasAny(['displayName']) || (data.displayName is string && data.displayName.size() <= 100))
        && (!data.keys().hasAny(['preferences']) || (data.preferences is list && data.preferences.size() <= 50));
    }

    function isValidPurchase(data) {
      return data.keys().hasAll(['bookId', 'purchasedAt'])
        && data.bookId is string && data.bookId.size() > 0 && data.bookId.size() <= 100
        && data.purchasedAt is int;
    }

    function isValidHistoryItem(data) {
      return data.keys().hasAll(['bookId', 'readAt'])
        && data.bookId is string && data.bookId.size() > 0 && data.bookId.size() <= 100
        && data.readAt is int;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['userId', 'bookId', 'rating', 'createdAt'])
        && data.userId is string && data.userId.size() > 0 && data.userId.size() <= 128
        && data.bookId is string && data.bookId.size() > 0 && data.bookId.size() <= 100
        && data.rating is int && data.rating >= 1 && data.rating <= 5
        && (!data.keys().hasAny(['comment']) || (data.comment is string && data.comment.size() <= 1000))
        && data.createdAt is int;
    }

    match /users/{userId} {
      allow get: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
      allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId 
                    && isValidUserProfile(incoming());
      allow update: if isSignedIn() && isValidId(userId) && request.auth.uid == userId 
                    && isValidUserProfile(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'preferences']);
      allow delete: if false;

      match /purchases/{purchaseId} {
        allow list, get: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
        allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId
                      && isValidPurchase(incoming())
                      && exists(/databases/$(database)/documents/users/$(userId));
        allow delete: if false;
      }

      match /history/{historyId} {
        allow list, get: if isSignedIn() && isValidId(userId) && request.auth.uid == userId;
        allow create: if isSignedIn() && isValidId(userId) && request.auth.uid == userId
                      && isValidHistoryItem(incoming())
                      && exists(/databases/$(database)/documents/users/$(userId));
        allow delete: if false;
      }
    }

    match /reviews/{reviewId} {
      allow get: if isValidId(reviewId);
      allow list: if isValidId(reviewId) || true; // Publicly readable list for reviews
      allow create: if isSignedIn() && isValidId(reviewId) 
                    && isValidReview(incoming()) 
                    && request.auth.uid == incoming().userId
                    && exists(/databases/$(database)/documents/users/$(request.auth.uid));
      allow update: if isSignedIn() && isValidId(reviewId) 
                    && request.auth.uid == existing().userId
                    && isValidReview(incoming())
                    && incoming().userId == existing().userId
                    && incoming().bookId == existing().bookId
                    && incoming().createdAt == existing().createdAt
                    && incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'comment']);
      allow delete: if isSignedIn() && isValidId(reviewId) && request.auth.uid == existing().userId;
    }
  }
}
